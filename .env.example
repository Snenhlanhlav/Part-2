# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
FRONTEND_ORIGIN=https://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/payment_portal

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# ── SSL ───────────────────────────────────────────────────────────────────────
# Generate self-signed cert for dev:
# openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout config/key.pem -out config/cert.pem
